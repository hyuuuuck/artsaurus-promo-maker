IMAGE_GENERATION_PROVIDER=mock
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image

CUTOUT_PROVIDER=sharp
REMBG_ENDPOINT=http://localhost:7000/api/remove
REMBG_MODEL=u2net_human_seg
REMBG_TIMEOUT_MS=90000

FACE_IDENTITY_CHECK=auto
FACE_IDENTITY_PROVIDER=local
FACE_IDENTITY_MIN_SCORE=0.88
FACE_IDENTITY_MIN_LOCAL_SCORE=0.82
FACE_IDENTITY_MAX_ATTEMPTS=10
FACE_IDENTITY_STRICT=0
DEEPFACE_API_URL=http://localhost:5006
DEEPFACE_MODEL=ArcFace
DEEPFACE_DETECTOR_BACKEND=retinaface
DEEPFACE_DISTANCE_METRIC=cosine
DEEPFACE_TIMEOUT_MS=45000

POSTER_ORCHESTRATOR_PLANNER=auto
POSTER_ORCHESTRATOR_MODEL=gemini-2.5-flash
POSTER_PROPOSAL_VARIANT_PROVIDER=auto
POSTER_PROPOSAL_VARIANT_CANDIDATE_POOL_SIZE=10

COMFYUI_BASE_URL=
COMFYUI_API_KEY=
COMFYUI_BACKGROUND_WORKFLOW_PATH=
COMFYUI_POSE_WORKFLOW_PATH=
COMFYUI_TIMEOUT_MS=180000
COMFYUI_POLL_MS=1200
